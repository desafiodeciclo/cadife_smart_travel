# =============================================================================
# backend/.env.example — Cadife Smart Travel
# =============================================================================
# Copie este arquivo para backend/.env e preencha os valores reais.
# NUNCA commite o arquivo .env no Git.
#
# Gerar JWT_SECRET_KEY seguro:
#   python -c "import secrets; print(secrets.token_hex(32))"
#
# Gerar ENCRYPTION_KEY (Fernet):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# =============================================================================

# ── Aplicação ────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
DEBUG=true                   # true apenas em desenvolvimento local

# ── WhatsApp Cloud API (Meta for Developers) ─────────────────────────────────
# Obtenha em: https://developers.facebook.com → Seu App → WhatsApp → Configuração
WHATSAPP_TOKEN=your_meta_whatsapp_access_token_here
PHONE_NUMBER_ID=your_meta_phone_number_id_here
VERIFY_TOKEN=cadife_verify_token_change_me
META_APP_SECRET=your_meta_app_secret_here
META_APP_ID=your_meta_app_id_here

# ── Google Gemini (obrigatório — LLM + embeddings) ───────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here
# ── OpenAI / LangChain (obrigatório — LLM + embeddings) ─────────────────────────
# Get your key at: https://platform.openai.com/api-keys
#OPENAI_API_KEY=your_openai_api_key_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Dev local (API fora do Docker): use localhost:5433 (porta mapeada pelo Compose)
# Dev local (API dentro do Docker via docker-compose.yml): o Compose sobrescreve para 'db:5432'
DATABASE_URL=postgresql+asyncpg://cadife:cadife@localhost:5433/cadife_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Dev local (API fora do Docker): use localhost:6379
# Se precisar de autenticação (staging/prod), use REDIS_HOST + REDIS_PASSWORD
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=DEV_            # prefixo das chaves — evita colisão entre ambientes

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WEBHOOK=100/minute
RATE_LIMIT_IA=30/minute
RATE_LIMIT_DEFAULT=60/minute

# ── Request Timeouts ─────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30.0
WEBHOOK_TIMEOUT_SECONDS=4.5  # Meta exige resposta HTTP 200 em < 5s

# ── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista separada por vírgulas de origens permitidas
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:4200

# ── Firebase Admin SDK (FCM — notificações push) ─────────────────────────────
# Gere em: console.firebase.google.com → Configurações do projeto → Contas de serviço
FIREBASE_CREDENTIALS=./firebase_credentials.json

# ── ChromaDB (Vector DB para RAG) ────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
KNOWLEDGE_BASE_DIR=./knowledge_base
INGESTION_CACHE_PATH=./chroma_db/ingestion_cache.json

# ── Criptografia PII at-rest (Fernet/AES-128) ────────────────────────────────
ENCRYPTION_KEY=
HASH_KEY=                    # HMAC-SHA256 para indexação de telefone (busca segura)

# ── Observabilidade (opcional) ────────────────────────────────────────────────
# LangSmith — rastreamento de chains LangChain
LANGCHAIN_API_KEY=

# Langfuse — alternativa ao LangSmith para métricas de qualidade de LLM
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── ngrok (apenas desenvolvimento local) ─────────────────────────────────────
# Token gratuito em: https://dashboard.ngrok.com/get-started/your-authtoken
# Sem token: sessão expira em 2h e URL muda a cada restart.
# Com token: sem limite de tempo; opcionalmente configure NGROK_DOMAIN abaixo.
NGROK_AUTHTOKEN=seu_ngrok_authtoken_aqui

# Domínio ngrok estático (plano pago) — elimina a necessidade de reconfigurar
# o webhook no Meta a cada restart. Deixe vazio para usar URL dinâmica.
NGROK_DOMAIN=

# ── Business Rules ───────────────────────────────────────────────────────────
# Dias de inatividade antes de um lead ser marcado automaticamente como PERDIDO
LEAD_EXPIRATION_DAYS=30

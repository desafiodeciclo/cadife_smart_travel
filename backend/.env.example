# Application
APP_ENV=development     # development | staging | production
DEBUG=false             # true only in local dev

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────
WHATSAPP_TOKEN=your_meta_whatsapp_access_token_here
PHONE_NUMBER_ID=your_meta_phone_number_id_here
VERIFY_TOKEN=cadife_verify_token_change_me
META_APP_SECRET=your_meta_app_secret_here
META_APP_ID=your_meta_app_id_here

# ── OpenAI (LangChain / RAG) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here

# ── LangSmith (optional — observability) ─────────────────────────────────
LANGCHAIN_API_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cadife:cadife@localhost:5432/cadife_db

# ── JWT Authentication ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase Admin SDK (FCM) ──────────────────────────────────────────────
FIREBASE_CREDENTIALS=./firebase_credentials.json

# ── ChromaDB (Vector DB for RAG) ─────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# LangSmith (opcional)
LANGCHAIN_API_KEY=

# Debug
DEBUG=false

# Rate Limiting (Redis)
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_WEBHOOK=100/minute
RATE_LIMIT_IA=30/minute
RATE_LIMIT_DEFAULT=60/minute

# Criptografia PII at-rest (Fernet/AES)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
# ── Request Timeouts ──────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30.0
WEBHOOK_TIMEOUT_SECONDS=4.5

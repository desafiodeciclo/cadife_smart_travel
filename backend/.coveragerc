[run]
source = app
omit = 
    */tests/*
    */venv/*
    */env/*
    */migrations/*
    */alembic/*
    */__pycache__/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == "__main__":
    raise AssertionError
    raise NotImplementedError
    if TYPE_CHECKING:
    @abstractmethod

# Cadife Smart Travel — Template de Variáveis de Ambiente
# Copie este arquivo para backend/.env e preencha os valores reais

# WhatsApp Cloud API (Meta Developer Console)
WHATSAPP_TOKEN=seu_token_de_acesso_meta
PHONE_NUMBER_ID=seu_phone_number_id
VERIFY_TOKEN=cadife_verify_token_secreto

# OpenAI (platform.openai.com)
OPENAI_API_KEY=sk-...

# Banco de Dados PostgreSQL
# Dev local (fora do Docker): use localhost
# Dentro do Docker: o compose sobrescreve automaticamente para 'db'
DATABASE_URL=postgresql+asyncpg://cadife:cadife@localhost:5432/cadife_db

# Redis (rate limiting e cache de sessão)
# Dev local: redis://localhost:6379/0 — Dentro do Docker: sobrescrito para 'redis'
REDIS_URL=redis://localhost:6379/0

# JWT (gere uma string aleatória forte: openssl rand -hex 32)
JWT_SECRET_KEY=chave-secreta-forte-aqui

# Firebase Admin SDK (console.firebase.google.com → Configurações do projeto → Contas de serviço)
FIREBASE_CREDENTIALS=./firebase_credentials.json

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# LangSmith (opcional — para observabilidade das chains)
LANGCHAIN_API_KEY=

# Modo debug (false em produção)
DEBUG=false

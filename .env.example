# =============================================================================
# .env.example — Cadife Smart Travel (raiz do projeto)
# =============================================================================
# Este arquivo é uma referência rápida. O arquivo canônico e completo
# com todas as variáveis está em:  backend/.env.example
#
# Para configurar o ambiente de desenvolvimento:
#   cp backend/.env.example backend/.env
#   # Preencha os valores e então execute:
#   ./dev.sh
# =============================================================================

# ── Aplicação ────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true

# ── WhatsApp Cloud API (Meta for Developers) ─────────────────────────────────
WHATSAPP_TOKEN=seu_token_de_acesso_meta
PHONE_NUMBER_ID=seu_phone_number_id
VERIFY_TOKEN=cadife_verify_token_secreto
META_APP_SECRET=seu_meta_app_secret
META_APP_ID=seu_meta_app_id

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=sua_chave_gemini_aqui

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cadife:cadife@localhost:5433/cadife_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=chave-secreta-forte-aqui

# ── Firebase Admin SDK (FCM) ──────────────────────────────────────────────────
FIREBASE_CREDENTIALS=./firebase_credentials.json

# ── ChromaDB (RAG) ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Criptografia PII ─────────────────────────────────────────────────────────
ENCRYPTION_KEY=
HASH_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── ngrok (dev local) ────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=seu_ngrok_authtoken_aqui
NGROK_DOMAIN=

# ── Observabilidade (opcional) ────────────────────────────────────────────────
LANGCHAIN_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
